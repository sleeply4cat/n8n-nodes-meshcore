{
	"name": "n8n-nodes-meshcore",
	"version": "0.1.0",
	"description": "n8n community nodes for MeshCore devices over TCP/WiFi",
	"license": "MIT",
	"homepage": "https://github.com/sleeply4cat/n8n-nodes-meshcore",
	"keywords": [
		"n8n-community-node-package",
		"meshcore",
		"mesh",
		"lora"
	],
	"author": {
		"name": "sleeply4cat",
		"email": "sleeply4cat@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/sleeply4cat/n8n-nodes-meshcore.git"
	},
	"scripts": {
		"build": "n8n-node build && node scripts/bundle-vendor.mjs",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"pretest": "n8n-node build && node scripts/bundle-vendor.mjs",
		"test": "node --test test/*.test.ts",
		"prepack": "n8n-node build && node scripts/bundle-vendor.mjs",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist",
		"!dist/tsconfig.tsbuildinfo"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/MeshCoreTcpApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/MeshCore/MeshCore.node.js",
			"dist/nodes/MeshCoreTrigger/MeshCoreTrigger.node.js"
		]
	},
	"devDependencies": {
		"@liamcottle/meshcore.js": "^1.13.0",
		"@n8n/node-cli": "*",
		"esbuild": "^0.28.0",
		"eslint": "9.29.0",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "6.0.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
